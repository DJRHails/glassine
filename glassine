#!/usr/bin/env bash
#
# glassine — transparent sops-backed encryption for git
#
# Glassine is the translucent archival paper used to protect valuable
# documents. This tool keeps sops envelopes in your git history while your
# working tree holds plaintext: opaque to the remote, transparent to anyone
# holding a key.
#
# https://github.com/DJRHails/glassine
set -euo pipefail

readonly VERSION='0.3.0'

GLASSINE_TMPDIR=''

die() {
  printf 'glassine: %s\n' "$*" >&2
  exit 1
}

warn() {
  printf 'glassine: %s\n' "$*" >&2
}

# Hard requirement on sops, with an actionable install hint. Deliberately
# never auto-installs: pulling a crypto engine onto the machine is the
# user's call, via their own package manager.
need_sops() {
  command -v sops >/dev/null 2>&1 && return 0
  local hint='https://github.com/getsops/sops/releases'
  if command -v brew >/dev/null 2>&1; then
    hint='brew install sops'
  elif command -v apt-get >/dev/null 2>&1; then
    hint='apt-get install sops (or grab a release: https://github.com/getsops/sops/releases)'
  elif command -v pacman >/dev/null 2>&1; then
    hint='pacman -S sops'
  elif command -v nix-env >/dev/null 2>&1; then
    hint='nix-env -iA nixpkgs.sops'
  fi
  die "sops is required but not installed — try: $hint"
}

ensure_tmpdir() {
  if [ -z "$GLASSINE_TMPDIR" ]; then
    GLASSINE_TMPDIR=$(mktemp -d "${TMPDIR:-/tmp}/glassine.XXXXXX")
    trap 'rm -rf -- "${GLASSINE_TMPDIR:?}"' EXIT
  fi
}

# A sops envelope always carries a MAC over its contents in its metadata,
# regardless of input type:
#   YAML:   mac: ENC[AES256_GCM,...      JSON: "mac": "ENC[AES256_GCM,...
#   dotenv: sops_mac=ENC[AES256_GCM,...  ini:  mac = ENC[AES256_GCM,...
# Matching on that is key-independent, so keyless hosts can recognise
# ciphertext too. (-a treats binary content as text.)
is_envelope() {
  LC_ALL=C grep -aqE 'mac[^[:alnum:]]{1,4}ENC\[AES256_GCM' "$1"
}

# Decrypt src into dst, presenting the repo-relative path to sops so that
# input-type detection and .sops.yaml creation rules behave as if the file
# were at its real location.
decrypt_to() { # <src> <dst> <repo-relative-path>
  sops decrypt --filename-override "$3" "$1" >"$2" 2>/dev/null
}

# ---------------------------------------------------------------------------
# git filter hooks
# ---------------------------------------------------------------------------

# clean: plaintext from stdin -> envelope on stdout (worktree -> repository).
#
# sops output is randomised (fresh data key, IVs, lastmodified, MAC), but git
# requires clean to be a pure function or every `git status` dirties the
# file. We restore purity by memoising against the index: when the staged
# envelope decrypts to exactly the incoming plaintext, re-emit it unchanged.
cmd_clean() { # <repo-relative-path>
  local path=$1
  need_sops
  ensure_tmpdir
  local work="$GLASSINE_TMPDIR/work"
  cat >"$work"

  # sops refuses empty input ("must contain at least one document"); there is
  # nothing to protect anyway, so empty files pass through (as in transcrypt).
  if [ ! -s "$work" ]; then
    return
  fi

  # Already-encrypted content round-trips untouched, so keyless checkouts
  # can never corrupt (or double-encrypt) an envelope.
  if is_envelope "$work"; then
    cat "$work"
    return
  fi

  if [ "${GLASSINE_FORCE:-0}" != '1' ]; then
    local staged="$GLASSINE_TMPDIR/staged" staged_plain="$GLASSINE_TMPDIR/staged_plain"
    if git cat-file blob ":$path" >"$staged" 2>/dev/null && is_envelope "$staged"; then
      if decrypt_to "$staged" "$staged_plain" "$path" && cmp -s "$staged_plain" "$work"; then
        cat "$staged"
        return
      fi
    fi
  fi

  # Real change (or forced rotation): fresh envelope, fresh data key.
  sops encrypt --filename-override "$path" "$work" ||
    die "encryption failed for '$path' — do .sops.yaml creation_rules cover this path?"
}

# smudge: envelope from stdin -> plaintext on stdout (repository -> worktree).
# Never fails: hosts without a matching identity get the envelope verbatim,
# which clean passes back through unchanged.
cmd_smudge() { # <repo-relative-path>
  local path=$1
  ensure_tmpdir
  local work="$GLASSINE_TMPDIR/work" plain="$GLASSINE_TMPDIR/plain"
  cat >"$work"
  if command -v sops >/dev/null 2>&1 && decrypt_to "$work" "$plain" "$path"; then
    cat "$plain"
  else
    cat "$work"
  fi
}

# textconv: decrypt a blob for diff display. git hands us a bare temporary
# file with the original extension lost, so probe likely input types.
cmd_textconv() { # <file>
  local file=$1 t
  if command -v sops >/dev/null 2>&1; then
    for t in json yaml dotenv ini binary; do
      if sops decrypt --input-type "$t" --output-type "$t" "$file" 2>/dev/null; then
        return
      fi
    done
  fi
  cat "$file"
}

# merge: three-way merge in plaintext space. git stores %A's bytes verbatim
# as the resolution (clean is NOT applied), so on success we must re-encrypt;
# on conflict we leave plaintext with markers — the user resolves in the
# working tree and their `git add` re-encrypts.
cmd_merge() { # <base %O> <ours %A> <theirs %B> <marker-size %L> <path %P>
  [ $# -eq 5 ] || die 'usage (git-internal): glassine merge %O %A %B %L %P'
  local base=$1 ours=$2 theirs=$3 marker=$4 path=$5
  need_sops
  ensure_tmpdir

  local f plain="$GLASSINE_TMPDIR/merge_plain"
  for f in "$base" "$ours" "$theirs"; do
    if [ -s "$f" ] && is_envelope "$f"; then
      if decrypt_to "$f" "$plain" "$path"; then
        cat "$plain" >"$f"
      else
        warn "cannot decrypt $path on this host — merging at ciphertext level"
      fi
    fi
  done

  if git merge-file --marker-size="$marker" -L ours -L base -L theirs \
    "$ours" "$base" "$theirs" >/dev/null 2>&1; then
    sops encrypt --filename-override "$path" "$ours" >"$GLASSINE_TMPDIR/merge_enc" ||
      die "re-encryption after merge failed for '$path'"
    cat "$GLASSINE_TMPDIR/merge_enc" >"$ours"
    return 0
  fi
  return 1
}

# ---------------------------------------------------------------------------
# repository commands
# ---------------------------------------------------------------------------

# Tracked paths whose filter attribute is glassine, NUL-separated on stdout.
managed_files() {
  git ls-files -z |
    git check-attr --stdin -z filter |
    while IFS= read -r -d '' p && IFS= read -r -d '' _ && IFS= read -r -d '' v; do
      if [ "$v" = 'glassine' ]; then
        printf '%s\0' "$p"
      fi
    done
}

# ---------------------------------------------------------------------------
# recipient management (.sops.yaml)
#
# glassine generates a single catch-all creation rule: WHICH files are
# protected is decided solely by .gitattributes (glassine protect), so
# .sops.yaml only answers WHO may read. Auto-editing is gated on the
# "managed by glassine" marker — hand-written files are never rewritten.
# ---------------------------------------------------------------------------

sops_yaml_managed() { # <file>
  head -1 "$1" 2>/dev/null | grep -q 'managed by glassine'
}

# Key tokens from a managed .sops.yaml (keys only appear on recipient lines).
policy_keys() { # <file>
  LC_ALL=C grep -aoE 'ssh-(ed25519|rsa) [A-Za-z0-9+/=]+|age1[0-9a-z]+' "$1" | sort -u || true
}

# Key tokens an envelope is actually wrapped to. Restricted to lines that
# mention "recipient" so base64 payload can't false-match.
envelope_keys() { # <file>
  LC_ALL=C grep -a 'recipient' "$1" |
    LC_ALL=C grep -aoE 'ssh-(ed25519|rsa) [A-Za-z0-9+/=]+|age1[0-9a-z]+' | sort -u || true
}

create_sops_yaml() { # <file>
  cat >"$1" <<'EOF'
# managed by glassine — edit recipients via `glassine allow` / `glassine revoke`
creation_rules:
  - key_groups:
      - age:
EOF
}

# Append one recipient under the first `- age:` list. Returns 1 on duplicate.
add_recipient() { # <file> <key> <comment>
  local file=$1 key=$2 comment=$3 tmp
  if grep -qF "$key" "$file"; then
    warn "already a recipient: ${comment:-$key}"
    return 1
  fi
  ensure_tmpdir
  tmp="$GLASSINE_TMPDIR/sops_yaml"
  awk -v line="          - '${key}'${comment:+ # ${comment}}" '
    { print }
    !done && $0 ~ /- age:[[:space:]]*$/ { print line; done = 1 }
  ' "$file" >"$tmp"
  cat "$tmp" >"$file"
}

# Resolve one allow argument into "key<TAB>comment" lines on stdout.
# Accepts a literal key, a path to a .pub file, or github:<user>.
resolve_recipients() { # <arg>
  local arg=$1 t b _rest user found=0
  case "$arg" in
  github:*)
    user=${arg#github:}
    command -v curl >/dev/null 2>&1 || die 'curl is required for github:<user> recipients'
    while read -r t b _rest; do
      case "$t" in
      ssh-ed25519 | ssh-rsa)
        printf '%s %s\tgithub:%s\n' "$t" "$b" "$user"
        found=1
        ;;
      esac
    done < <(curl -fsSL "https://github.com/${user}.keys" 2>/dev/null || true)
    [ "$found" -eq 1 ] || die "no usable SSH keys at github.com/${user}.keys"
    ;;
  ssh-ed25519\ * | ssh-rsa\ *)
    read -r t b _rest <<<"$arg"
    printf '%s %s\t%s\n' "$t" "$b" "${_rest:-}"
    ;;
  age1*)
    printf '%s\t\n' "$arg"
    ;;
  *)
    [ -f "$arg" ] || die "not a key, key file, or github:<user>: $arg"
    read -r t b _rest <"$arg"
    case "$t" in
    ssh-ed25519 | ssh-rsa) printf '%s %s\t%s\n' "$t" "$b" "${_rest:-$arg}" ;;
    *) die "unsupported key type '$t' in $arg (age accepts ssh-ed25519 and ssh-rsa)" ;;
    esac
    ;;
  esac
}

# Re-encrypt staged managed files if there are any (used after ACL changes).
rotate_if_managed() {
  local f
  while IFS= read -r -d '' f; do
    cmd_rotate
    return
  done < <(managed_files)
}

cmd_allow() { # <key | path/to/key.pub | github:user>...
  [ $# -gt 0 ] || die 'usage: glassine allow <ssh-pubkey | key-file.pub | github:user>...'
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || die 'not inside a git repository'
  need_sops
  ensure_tmpdir

  local recips="$GLASSINE_TMPDIR/recips" arg
  : >"$recips"
  for arg in "$@"; do
    resolve_recipients "$arg" >>"$recips"
  done
  [ -s "$recips" ] || die 'no recipients resolved'

  local sops_yaml="$root/.sops.yaml"
  if [ ! -f "$sops_yaml" ]; then
    create_sops_yaml "$sops_yaml"
  elif ! sops_yaml_managed "$sops_yaml"; then
    die '.sops.yaml is not managed by glassine — add recipients there manually'
  fi

  local key comment added=0
  while IFS=$'\t' read -r key comment; do
    if add_recipient "$sops_yaml" "$key" "$comment"; then
      printf 'glassine: allowed %s\n' "${comment:-$key}"
      added=$((added + 1))
    fi
  done <"$recips"

  if [ "$added" -gt 0 ]; then
    rotate_if_managed
  fi
}

cmd_revoke() { # <pattern>
  [ $# -eq 1 ] || die 'usage: glassine revoke <pattern matching a recipient line>'
  local pattern=$1 root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || die 'not inside a git repository'
  need_sops
  local sops_yaml="$root/.sops.yaml"
  [ -f "$sops_yaml" ] || die 'no .sops.yaml in this repository'
  sops_yaml_managed "$sops_yaml" || die '.sops.yaml is not managed by glassine — remove recipients there manually'

  ensure_tmpdir
  local tmp="$GLASSINE_TMPDIR/sops_yaml" removed remaining
  # Recipient lines look like:       - 'ssh-ed25519 AAAA...' # comment
  removed=$(grep -cE "^[[:space:]]+- '.*${pattern}" "$sops_yaml" || true)
  [ "$removed" -gt 0 ] || die "no recipient matches: $pattern"
  awk -v pat="$pattern" '
    $0 ~ /^[[:space:]]+- '\''/ && $0 ~ pat { next }
    { print }
  ' "$sops_yaml" >"$tmp"
  remaining=$(grep -cE "^[[:space:]]+- '" "$tmp" || true)
  [ "$remaining" -gt 0 ] || die "refusing to remove the last recipient ($pattern matches all of them)"
  cat "$tmp" >"$sops_yaml"
  printf 'glassine: revoked %d recipient(s) matching %s\n' "$removed" "$pattern"

  rotate_if_managed
  warn 'revocation is forward-only: the revoked key keeps history it could already read — rotate the secret values too if this was a compromise'
}

cmd_protect() { # <glob>...
  [ $# -gt 0 ] || die "usage: glassine protect <glob>...  (e.g. glassine protect 'secrets/**')"
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || die 'not inside a git repository'
  need_sops

  local attrs="$root/.gitattributes" g line
  for g in "$@"; do
    line="$g filter=glassine diff=glassine merge=glassine"
    if [ -f "$attrs" ] && grep -qxF "$line" "$attrs"; then
      warn "already protected: $g"
      continue
    fi
    printf '%s\n' "$line" >>"$attrs"
    printf 'glassine: protecting %s\n' "$g"
  done

  # Encrypt any already-tracked plaintext now covered by the new globs.
  ensure_tmpdir
  local f blob="$GLASSINE_TMPDIR/blob" reencrypted=0
  while IFS= read -r -d '' f; do
    if git cat-file blob ":$f" >"$blob" 2>/dev/null && ! is_envelope "$blob"; then
      git add --renormalize -- "$f"
      reencrypted=$((reencrypted + 1))
    fi
  done < <(managed_files)
  if [ "$reencrypted" -gt 0 ]; then
    printf 'glassine: re-staged %d previously-plaintext file(s) encrypted — review and commit\n' "$reencrypted"
    warn 'their plaintext remains in earlier commits; rotate those secret values if sensitive'
  fi
}

cmd_init() {
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || die 'not inside a git repository'
  need_sops
  command -v glassine >/dev/null 2>&1 ||
    warn 'glassine is not on PATH; the filters below will fail until it is'

  git config filter.glassine.clean 'glassine clean %f'
  git config filter.glassine.smudge 'glassine smudge %f'
  # A failing clean must abort the operation; without this git would silently
  # stage plaintext when the filter errors.
  git config filter.glassine.required true
  git config diff.glassine.textconv 'glassine textconv'
  git config merge.glassine.name 'glassine three-way merge of sops envelopes'
  git config merge.glassine.driver 'glassine merge %O %A %B %L %P'

  if [ ! -f "$root/.sops.yaml" ]; then
    local pub='' candidate t b _rest
    for candidate in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub"; do
      if [ -f "$candidate" ]; then
        pub=$candidate
        break
      fi
    done
    if [ -n "$pub" ]; then
      create_sops_yaml "$root/.sops.yaml"
      read -r t b _rest <"$pub"
      add_recipient "$root/.sops.yaml" "$t $b" "${_rest:-$(hostname)}" || true
      printf "glassine: created .sops.yaml with this host's key (%s)\n" "$pub"
      printf 'glassine: add more recipients with: glassine allow <key | key.pub | github:user>\n'
    else
      warn 'no .sops.yaml and no ~/.ssh key found — bootstrap recipients with: glassine allow <key>'
    fi
  fi

  # Refresh worktree copies that are still ciphertext (e.g. right after
  # cloning, before the filter existed). Note: checkout-index bypasses smudge
  # filters, so delete + checkout is the reliable re-smudge idiom.
  ensure_tmpdir
  local f refreshed=0
  while IFS= read -r -d '' f; do
    if [ -f "$root/$f" ] && is_envelope "$root/$f"; then
      rm -f -- "$root/$f"
      git checkout -- "$f"
      refreshed=$((refreshed + 1))
    fi
  done < <(managed_files)
  [ "$refreshed" -eq 0 ] || printf 'glassine: decrypted %d file(s) into the working tree\n' "$refreshed"

  printf 'glassine: filters configured for %s\n' "$root"
  printf "glassine: choose what to protect, e.g.: glassine protect 'secrets/**'\n"
}

cmd_uninstall() {
  git rev-parse --show-toplevel >/dev/null 2>&1 || die 'not inside a git repository'
  git config --remove-section filter.glassine 2>/dev/null || true
  git config --remove-section diff.glassine 2>/dev/null || true
  warn 'filters removed; working-tree plaintext is untouched but future checkouts produce ciphertext'
}

# Force re-encryption with fresh data keys under the current .sops.yaml.
# Run after changing recipients: removing a recipient without rotating only
# stops them reading *future* envelopes once content changes — this command
# makes the cut immediate and mints new data keys (sops rotate semantics).
cmd_rotate() { # [paths...]
  local files=()
  if [ $# -gt 0 ]; then
    files=("$@")
  else
    local f
    while IFS= read -r -d '' f; do files+=("$f"); done < <(managed_files)
  fi
  [ ${#files[@]} -gt 0 ] || die 'no glassine-managed files found (set "filter=glassine" in .gitattributes)'
  GLASSINE_FORCE=1 git add --renormalize -- "${files[@]}"
  printf 'glassine: re-encrypted %d file(s) with fresh data keys — review and commit\n' "${#files[@]}"
}

# Verify every staged managed file is an envelope, and (for a glassine-managed
# .sops.yaml) that each envelope's recipient set matches policy. Run as a
# pre-commit hook. Catches two failure classes:
#  - the filter silently not running (.gitattributes set, git config missing)
#  - recipient drift: merging a branch that changed .sops.yaml re-encrypts
#    envelopes under the pre-merge policy, so newly-allowed keys silently
#    can't read (and newly-revoked ones still can) until a rotate
cmd_check() {
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || die 'not inside a git repository'
  ensure_tmpdir
  local f bad=0 drift=0 blob="$GLASSINE_TMPDIR/blob" policy=''
  if [ -f "$root/.sops.yaml" ] && sops_yaml_managed "$root/.sops.yaml"; then
    policy=$(policy_keys "$root/.sops.yaml")
  fi
  while IFS= read -r -d '' f; do
    # Empty blobs pass through unencrypted by design — nothing to protect.
    if ! git cat-file blob ":$f" >"$blob" 2>/dev/null || [ ! -s "$blob" ]; then
      continue
    fi
    if ! is_envelope "$blob"; then
      printf 'glassine: NOT ENCRYPTED in index: %s\n' "$f" >&2
      bad=1
    elif [ -n "$policy" ] && [ "$(envelope_keys "$blob")" != "$policy" ]; then
      printf 'glassine: RECIPIENT DRIFT in index: %s\n' "$f" >&2
      drift=1
    fi
  done < <(managed_files)
  [ "$bad" -eq 0 ] || die 'plaintext staged for managed paths — run "glassine init" then "glassine rotate"'
  [ "$drift" -eq 0 ] || die 'envelopes do not match .sops.yaml recipients (common after merges) — run "glassine rotate" and commit'
}

cmd_status() {
  ensure_tmpdir
  local f state blob="$GLASSINE_TMPDIR/blob"
  while IFS= read -r -d '' f; do
    state='not-staged'
    if git cat-file blob ":$f" >"$blob" 2>/dev/null; then
      if is_envelope "$blob"; then
        state='encrypted'
      elif [ ! -s "$blob" ]; then
        state='empty'
      else
        state='PLAINTEXT'
      fi
    fi
    printf '%-11s %s\n' "$state" "$f"
  done < <(managed_files)
}

usage() {
  cat <<'EOF'
glassine — transparent sops-backed encryption for git

USAGE
  glassine <command> [args]

COMMANDS
  init           configure this repository (idempotent): filters + merge
                 driver; bootstraps .sops.yaml with this host's SSH key;
                 decrypts still-encrypted worktree files (e.g. after cloning)
  protect <g>…   protect globs: writes .gitattributes lines and encrypts any
                 already-tracked plaintext matches
  allow <r>…     add recipients: a literal key, a .pub file, or github:user
                 (fetches github.com/<user>.keys); re-encrypts managed files
  revoke <pat>   remove recipients matching <pat> and rotate data keys
                 (forward-only: rotate secret values too on compromise)
  status         list managed files and their index state
  check          fail if any staged managed file is unencrypted (pre-commit)
  rotate [f…]    force re-encryption with fresh data keys under .sops.yaml
  uninstall      remove the filter configuration from this repository
  version        print version

INTERNAL (invoked by git)
  clean / smudge / textconv / merge

QUICKSTART (per repository)
  glassine init
  glassine protect 'secrets/**'
  glassine allow github:teammate     # optional
EOF
}

main() {
  local cmd=${1:-help}
  shift || true
  case "$cmd" in
  clean) cmd_clean "$@" ;;
  smudge) cmd_smudge "$@" ;;
  textconv) cmd_textconv "$@" ;;
  merge) cmd_merge "$@" ;;
  init) cmd_init "$@" ;;
  protect) cmd_protect "$@" ;;
  allow) cmd_allow "$@" ;;
  revoke) cmd_revoke "$@" ;;
  uninstall) cmd_uninstall "$@" ;;
  rotate) cmd_rotate "$@" ;;
  check) cmd_check "$@" ;;
  status) cmd_status "$@" ;;
  version | --version | -v) printf 'glassine %s\n' "$VERSION" ;;
  help | --help | -h) usage ;;
  *) die "unknown command: $cmd (try: glassine help)" ;;
  esac
}

main "$@"
